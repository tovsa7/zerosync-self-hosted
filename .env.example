# ZeroSync — environment variables
# Copy to .env and fill in your values before running docker compose up.

# ── Required ──────────────────────────────────────────────────────────────────

# Your domain. Caddy will obtain a TLS certificate from Let's Encrypt.
ZEROSYNC_DOMAIN=sync.example.com

# License key issued by ZeroSync (JWT string).
# Leave empty to run on the Free tier (5 rooms, 10 peers/room).
ZEROSYNC_LICENSE_KEY=

# HMAC-SHA256 signing secret provided with your license (min 32 bytes).
# Required when ZEROSYNC_LICENSE_KEY is set.
ZEROSYNC_LICENSE_SECRET=

# ── Relay ─────────────────────────────────────────────────────────────────────

# Region tag shown to SDK clients (e.g. "us-east", "eu-de", "ap-tokyo").
RELAY_REGION=us-east

# Room the relay joins on startup.
RELAY_ROOM_ID=default

# ── Optional ──────────────────────────────────────────────────────────────────

# Number of OS threads for the signaling server (default: 2).
GOMAXPROCS=2
